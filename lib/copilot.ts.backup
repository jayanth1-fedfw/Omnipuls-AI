import type {
  AssistantMode,
  AssistantResponse,
  CopilotSuggestion,
  ManualAlertInput,
  OmnipulsState,
  Priority,
  TaskInput
} from "@/lib/types";

type OpenAIResponse = {
  output_text?: string;
  output?: Array<{
    content?: Array<{
      text?: string;
    }>;
  }>;
};

export async function generateCopilotSuggestion(message: string, state: OmnipulsState): Promise<CopilotSuggestion> {
  if (process.env.OPENAI_API_KEY) {
    const remote = await generateWithOpenAIAssistant(message, state);
    if (remote) {
      return remote;
    }
  }

  return generateLocalSuggestion(message, state);
}

export async function generateAssistantResponse(
  message: string,
  mode: AssistantMode,
  state: OmnipulsState
): Promise<AssistantResponse> {
  if (process.env.OPENAI_API_KEY) {
    const remote = await generateWithOpenAIAssistant(message, state, mode);
    if (remote) {
      return remote;
    }
  }

  return generateLocalAssistant(message, state, mode);
}

async function generateWithOpenAIAssistant(message: string, state: OmnipulsState): Promise<CopilotSuggestion | null> {
  if (!process.env.OPENAI_ASSISTANT_ID) {
    // Fallback to Responses API if assistant ID not set
    return await generateWithOpenAIResponses(message, state);
  }

  const assistantId = process.env.OPENAI_ASSISTANT_ID;
  try {
    const thread = await createThread();
    const threadId = thread.id;

    // Prepare the input content similar to before
    const inputContent = JSON.stringify({
      request: message,
      existingTasks: state.tasks.slice(0, 8),
      memories: state.memories.slice(0, 8),
      manualAlerts: state.manualAlerts.slice(0, 8),
      now: new Date().toISOString()
    });

    const userMessage = You are Omnipuls, a customer-work alert AI. Return only JSON with keys reply, memory, task, manualAlert. task must include customerName, workGoal, sourceMemory, deadline ISO string, dailyTime HH:MM, priority low|medium|high|critical, status active|complete. manualAlert must include message and alertAt ISO string. Omit keys you cannot infer.

Input:
\;

    await addMessage(threadId, userMessage);
    const run = await createRun(threadId, assistantId);
    const completedRun = await pollRun(threadId, run.id);

    if (completedRun.status !== "completed") {
      throw new Error(\Assistant run failed with status: \\);
    }

    const messages = await getMessages(threadId);
    // Get the latest assistant message
    const assistantMessage = messages.data.find(msg => msg.role === "assistant");
    if (!assistantMessage) {
      throw new Error("No assistant message found");
    }

    // Extract text content from the message
    const textContent = assistantMessage.content
      .find((block: any) => block.type === "text")?.text?.value;

    if (!textContent) {
      throw new Error("No text content in assistant message");
    }

    try {
      return normalizeSuggestion(JSON.parse(textContent));
    } catch {
      return null;
    }
  } catch (error) {
    console.error("Error in assistant call:", error);
    // Fallback to Responses API on error
    return await generateWithOpenAIResponses(message, state);
  }
}

async function generateWithOpenAIAssistant(message: string, state: OmnipulsState, mode: AssistantMode): Promise<AssistantResponse | null> {
  if (!process.env.OPENAI_ASSISTANT_ID) {
    // Fallback to Responses API if assistant ID not set
    return await generateWithOpenAIResponses(message, state, mode);
  }

  const assistantId = process.env.OPENAI_ASSISTANT_ID;
  try {
    const thread = await createThread();
    const threadId = thread.id;

    // Prepare the input content similar to before
    const inputContent = JSON.stringify({
      message,
      mode,
      tasks: state.tasks.slice(0, 6),
      memories: state.memories.slice(0, 6),
      manualAlerts: state.manualAlerts.slice(0, 6),
      now: new Date().toISOString()
    });

    const userMessage = You are Omnipuls Studio, a general AI assistant for workflow, deep learning help, research, and planning. Return structured JSON only.

Input:
\;

    await addMessage(threadId, userMessage);
    const run = await createRun(threadId, assistantId);
    const completedRun = await pollRun(threadId, run.id);

    if (completedRun.status !== "completed") {
      throw new Error(\Assistant run failed with status: \\);
    }

    const messages = await getMessages(threadId);
    // Get the latest assistant message
    const assistantMessage = messages.data.find(msg => msg.role === "assistant");
    if (!assistantMessage) {
      throw new Error("No assistant message found");
    }

    // Extract text content from the message
    const textContent = assistantMessage.content
      .find((block: any) => block.type === "text")?.text?.value;

    if (!textContent) {
      throw new Error("No text content in assistant message");
    }

    try {
      return normalizeAssistant(JSON.parse(textContent));
    } catch {
      return null;
    }
  } catch (error) {
    console.error("Error in assistant call:", error);
    // Fallback to Responses API on error
    return await generateWithOpenAIResponses(message, state, mode);
  }
}

// Helper functions for OpenAI Assistant API
async function createThread() {
  const response = await fetch("https://api.openai.com/v1/threads", {
    method: "POST",
    headers: {
      Authorization: \Bearer \\,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({})
  });

  if (!response.ok) {
    throw new Error(\Failed to create thread: \\);
  }
  return response.json();
}

async function addMessage(threadId: string, content: string) {
  const response = await fetch(\https://api.openai.com/v1/threads/\/messages\, {
    method: "POST",
    headers: {
      Authorization: \Bearer \\,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      role: "user",
      content
    })
  });

  if (!response.ok) {
    throw new Error(\Failed to add message: \\);
  }
  return response.json();
}

async function createRun(threadId: string, assistantId: string) {
  const response = await fetch(\https://api.openai.com/v1/threads/\/runs\, {
    method: "POST",
    headers: {
      Authorization: \Bearer \\,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      assistant_id: assistantId
    })
  });

  if (!response.ok) {
    throw new Error(\Failed to create run: \\);
  }
  return response.json();
}

async function pollRun(threadId: string, runId: string): Promise<any> {
  let attempts = 0;
  const maxAttempts = 30; // 30 seconds with 1 second interval
  while (attempts < maxAttempts) {
    const response = await fetch(\https://api.openai.com/v1/threads/\/runs/\\, {
      method: "GET",
      headers: {
        Authorization: \Bearer \\
      }
    });

    if (!response.ok) {
      throw new Error(\Failed to poll run: \\);
    }

    const run = await response.json();
    if (run.status === "completed" || run.status === "failed" || run.status === "cancelled" || run.status === "expired") {
      return run;
    }

    await new Promise(resolve => setTimeout(resolve, 1000)); // wait 1 second
    attempts++;
  }

  throw new Error("Assistant run timed out");
}

async function getMessages(threadId: string) {
  const response = await fetch(\https://api.openai.com/v1/threads/\/messages\, {
    method: "GET",
    headers: {
      Authorization: \Bearer \\
    }
  });

  if (!response.ok) {
    throw new Error(\Failed to get messages: \\);
  }
  return response.json();
}

// Fallback to Responses API (original implementation)
async function generateWithOpenAIResponses(message: string, state: OmnipulsState): Promise<CopilotSuggestion | null> {
  const response = await fetch("https://api.openai.com/v1/responses", {
    method: "POST",
    headers: {
      Authorization: \Bearer \\,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: process.env.OPENAI_MODEL || "gpt-4.1-mini",
      instructions:
        "You are Omnipuls, a customer-work alert AI. Return only JSON with keys reply, memory, task, manualAlert. task must include customerName, workGoal, sourceMemory, deadline ISO string, dailyTime HH:MM, priority low|medium|high|critical, status active|complete. manualAlert must include message and alertAt ISO string. Omit keys you cannot infer.",
      input: JSON.stringify({
        request: message,
        existingTasks: state.tasks.slice(0, 8),
        memories: state.memories.slice(0, 8),
        manualAlerts: state.manualAlerts.slice(0, 8),
        now: new Date().toISOString()
      }),
      text: {
        format: {
          type: "json_object"
        }
      },
      max_output_tokens: 900
    })
  });

  if (!response.ok) {
    return null;
  }

  const data = (await response.json()) as OpenAIResponse;
  const text = data.output_text || data.output?.flatMap((item) => item.content || []).find((item) => item.text)?.text;

  if (!text) {
    return null;
  }

  try {
    return normalizeSuggestion(JSON.parse(text));
  } catch {
    return null;
  }
}

async function generateWithOpenAIResponses(
  message: string,
  state: OmnipulsState,
  mode: AssistantMode
): Promise<AssistantResponse | null> {
  const response = await fetch("https://api.openai.com/v1/responses", {
    method: "POST",
    headers: {
      Authorization: \Bearer \\,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: process.env.OPENAI_MODEL || "gpt-4o-mini",
      instructions:
        "You are Omnipuls Studio, a general AI assistant for workflow, deep learning help, research, and planning. Return structured JSON only.",
      input: JSON.stringify({
        message,
        mode,
        tasks: state.tasks.slice(0, 6),
        memories: state.memories.slice(0, 6),
        manualAlerts: state.manualAlerts.slice(0, 6),
        now: new Date().toISOString()
      }),
      text: {
        format: {
          type: "json_schema",
          name: "omnipuls_assistant_response",
          strict: true,
          schema: {
            type: "object",
            additionalProperties: false,
            properties: {
              reply: { type: "string" },
              mode: { type: "string", enum: ["general", "deep_learning", "workflow", "research"] },
              memory: { type: "string" },
              task: {
                type: "object",
                additionalProperties: false,
                properties: {
                  customerName: { type: "string" },
                  workGoal: { type: "string" },
                  sourceMemory: { type: "string" },
                  deadline: { type: "string", format: "date-time" },
                  dailyTime: { type: "string", pattern: "^[0-2][0-9]:[0-5][0-9]\$" },
                  priority: { type: "string", enum: ["low", "medium", "high", "critical"] },
                  status: { type: "string", enum: ["active", "complete"] }
                },
                required: ["customerName", "workGoal", "sourceMemory", "deadline", "dailyTime", "priority", "status"]
              },
              manualAlert: {
                type: "object",
                additionalProperties: false,
                properties: {
                  message: { type: "string" },
                  alertAt: { type: "string", format: "date-time" }
                },
                required: ["message", "alertAt"]
              },
              vaultEntry: {
                type: "object",
                additionalProperties: false,
                properties: {
                  title: { type: "string" },
                  note: { type: "string" },
                  tags: {
                    type: "array",
                    items: { type: "string" }
                  }
                }
              }
            }
          }
        }
      }),
      max_output_tokens: 900
    })
  });

  if (!response.ok) {
    return null;
  }

  const data = (await response.json()) as OpenAIResponse;
  const text = data.output_text || data.output?.flatMap((item) => item.content || []).find((item) => item.text)?.text;

  if (!text) {
    return null;
  }

  try {
    return normalizeAssistant(JSON.parse(text));
  } catch {
    return null;
  }
}

// The rest of the file remains unchanged: normalizeSuggestion, normalizeAssistant, etc.
function normalizeSuggestion(value: Partial<CopilotSuggestion>): CopilotSuggestion {
  return {
    reply: typeof value.reply === "string" ? value.reply : "I prepared a response.",
    memory: typeof value.memory === "string" ? value.memory : undefined,
    task: value.task ? normalizeTask(value.task) : undefined,
    manualAlert: value.manualAlert ? normalizeManualAlert(value.manualAlert) : undefined
  };
}

function normalizeAssistant(value: Partial<AssistantResponse>): AssistantResponse {
  return {
    reply: typeof value.reply === "string" ? value.reply : "I prepared a response.",
    mode: value.mode === "deep_learning" || value.mode === "workflow" || value.mode === "research" ? value.mode : "general",
    memory: typeof value.memory === "string" ? value.memory : undefined,
    task: value.task ? normalizeTask(value.task) : undefined,
    manualAlert: value.manualAlert ? normalizeManualAlert(value.manualAlert) : undefined,
    vaultEntry:
      value.vaultEntry && typeof value.vaultEntry.title === "string" && typeof value.vaultEntry.note === "string"
        ? {
            title: value.vaultEntry.title,
            note: value.vaultEntry.note,
            tags: Array.isArray(value.vaultEntry.tags) ? value.vaultEntry.tags.map(String).slice(0, 8) : []
          }
        : undefined
  };
}

function normalizeTask(value: Partial<TaskInput>): TaskInput | undefined {
  if (!value.customerName || !value.workGoal) {
    return undefined;
  }

  return {
    customerName: String(value.customerName),
    workGoal: String(value.workGoal),
    sourceMemory: String(value.sourceMemory || ""),
    deadline: validDate(value.deadline) || defaultDeadline(),
    dailyTime: /^\d{2}:\d{2}$/.test(String(value.dailyTime)) ? String(value.dailyTime) : "09:00",
    priority: isPriority(value.priority) ? value.priority : "medium",
    status: value.status === "complete" ? "complete" : "active"
  };
}

function normalizeManualAlert(value: Partial<ManualAlertInput>): ManualAlertInput | undefined {
  if (!value.message) {
    return undefined;
  }

  return {
    message: String(value.message),
    alertAt: validDate(value.alertAt) || defaultDeadline()
  };
}

function extractCustomerName(message: string) {
  const match = message.match(/\b(?:for|customer|client)\s+([A-Z][a-z]+(?:\s+[A-Z][a-z]+)?)/);
  return match?.[1];
}

function extractGoal(message: string) {
  const match = message.match(/\b(?:to|goal is|work is|need to)\s+(.+?)(?:\s+by|\s+before|\s+at|$)/i);
  return match?.[1]?.trim() || message.slice(0, 90);
}

function extractDeadline(message: string) {
  const date = new Date();

  if (message.includes("today")) {
    date.setHours(18, 0, 0, 0);
    return date.toISOString();
  }

  if (message.includes("tomorrow")) {
    date.setDate(date.getDate() + 1);
    date.setHours(18, 0, 0, 0);
    return date.toISOString();
  }

  const days = message.match(/in\s+(\d+)\s+days?/);
  if (days) {
    date.setDate(date.getDate() + Number(days[1]));
    date.setHours(18, 0, 0, 0);
    return date.toISOString();
  }

  return defaultDeadline();
}

function extractTime(message: string) {
  const match = message.match(/\b([01]?\d|2[0-3]):([0-5]\d)\b/);
  return match ? \\:\\ : undefined;
}

function defaultDeadline() {
  const date = new Date();
  date.setDate(date.getDate() + 3);
  date.setHours(18, 0, 0, 0);
  return date.toISOString();
}

function validDate(value: unknown) {
  if (typeof value !== "string") {
    return undefined;
  }

  const date = new Date(value);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
}

function isPriority(value: unknown): value is Priority {
  return value === "low" || value === "medium" || value === "high" || value === "critical";
}

function generateLocalSuggestion(message: string, state: OmnipulsState): CopilotSuggestion {
  const lower = message.toLowerCase();
  const reply =
    lower.includes("deadline") || lower.includes("follow up") || lower.includes("remind")
      ? "I've captured the request and can turn it into a structured action or memory entry."
      : "Iâ€™ve noted your request. Let me know if you'd like me to turn it into a task, memory, or manual alert.";

  return {
    reply,
    memory: message,
    task:
      lower.includes("deadline") || lower.includes("follow up") || lower.includes("remind")
        ? {
            customerName: state.tasks[0]?.customerName || "Customer",
            workGoal: message.slice(0, 80),
            sourceMemory: message,
            deadline: defaultDeadline(),
            dailyTime: "09:00",
            priority: "medium",
            status: "active"
          }
        : undefined
  };
}

function generateLocalAssistant(message: string, state: OmnipulsState, mode: AssistantMode): AssistantResponse {
  const lower = message.toLowerCase();
  const reply =
    mode === "deep_learning"
      ? "I can help with deep learning workflows: dataset prep, training plans, evaluation, debugging, and model summaries. Based on your note, I would start by turning this into a clear experiment log and action list."
      : mode === "research"
        ? "I can help structure the research question, collect context, and turn the answer into a reusable note inside the browser vault."
        : "Iâ€™ve captured the request and can turn it into a structured action or memory entry.";

  return {
    reply,
    mode,
    memory: message,
    vaultEntry: {
      title: mode === "deep_learning" ? "Deep Learning Note" : "Assistant Note",
      note: message,
      tags: mode === "deep_learning" ? ["deep-learning", "workflow"] : ["assistant"]
    },
    task:
      lower.includes("deadline") || lower.includes("follow up") || lower.includes("remind")
        ? {
            customerName: state.tasks[0]?.customerName || "Customer",
            workGoal: message.slice(0, 80),
            sourceMemory: message,
            deadline: defaultDeadline(),
            dailyTime: "09:00",
            priority: "medium",
            status: "active"
          }
        : undefined
  };
}
